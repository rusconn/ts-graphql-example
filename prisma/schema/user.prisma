model User {
  id        String   @id @pg.Uuid
  updatedAt DateTime
  avatar    String?  @pg.VarChar(300)
  name      String   @unique @pg.VarChar(15)
  handle    String   @pg.VarChar(50)
  bio       String   @default("") @pg.VarChar(160)
  location  String   @default("") @pg.VarChar(30)
  website   String   @default("") @pg.VarChar(100)
  email     String   @unique @pg.VarChar(100)
  password  String   @pg.VarChar(100)
  token     String?  @unique @pg.Uuid

  posts     Post[]
  likers    Like[]
  blockers  Block[]  @relation("blockedBy")
  blockees  Block[]  @relation("blocking")
  followers Follow[] @relation("followedBy")
  followees Follow[] @relation("following")
}
