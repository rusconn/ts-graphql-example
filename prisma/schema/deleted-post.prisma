model DeletedPost {
  id        String   @id @pg.Uuid
  updatedAt DateTime
  content   String   @pg.VarChar(280)
  userId    String   @pg.Uuid
  parentId  String?  @pg.Uuid // 外部キーなし。Post と DeletedPost の可能性があるため。

  user User @relation(fields: userId, references: id, onDelete: Cascade)

  // prismaが部分インデックスをサポートしていないようなので、マイグレーションファイルを作成後、DDLへ手で追加する。
  // 投稿の返信数。投稿のparents。
  // @@index(parentId, WHERE "parentId" IS NOT NULL)
}
