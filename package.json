{
  "private": true,
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~24.10",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9",
      "onFail": "error"
    }
  },
  "scripts": {
    "dev": "dotenvx run -- node --watch src/presentation/server.ts",
    "check": "tsgo && oxlint && oxfmt --check",
    "build": "vite build",
    "preview": "dotenvx run -f .env -f .env.preview --overload -- node --enable-source-maps dist/server.js",
    "test": "dotenvx run -f .env -f .env.test --overload -- pnpm run --sequential /test:/",
    "test:ut": "vitest --project ut",
    "test:setup": "pgschema apply --file db/schema.empty.sql --auto-approve && pgschema apply --file db/schema.sql --auto-approve",
    "test:it": "vitest --project it",
    "test:e2e": "vitest --project e2e",
    "db:typegen": "dotenvx run -- kysely-codegen --config-file kysely-codegen.ts",
    "db:seed": "dotenvx run -- node db/seed.ts",
    "gql:codegen": "dotenvx run -- node schemagen.ts && oxfmt schema.graphql && graphql-codegen-esm"
  },
  "dependencies": {
    "@envelop/core": "^5.5.1",
    "@escape.tech/graphql-armor": "^3.2.0",
    "@graphql-yoga/plugin-disable-introspection": "^2.7.0",
    "@whatwg-node/server-plugin-cookies": "^1.0.5",
    "bcrypt": "^6.0.0",
    "dataloader": "^2.2.3",
    "graphql": "^16.12.0",
    "graphql-fields": "^2.0.3",
    "graphql-query-complexity": "^0.12.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.7.0",
    "jose": "^6.1.3",
    "kysely": "^0.29.2",
    "neverthrow": "^8.2.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.56.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@faker-js/faker": "^10.3.0",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "5.0.8",
    "@graphql-codegen/typescript-operations": "^5.0.8",
    "@graphql-codegen/typescript-resolvers": "5.1.6",
    "@graphql-tools/executor-http": "^3.1.0",
    "@graphql-tools/utils": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/graphql-fields": "^1.3.9",
    "@types/pg": "^8.16.0",
    "@typescript/native-preview": "7.0.0-dev.20260220.1",
    "@whatwg-node/cookie-store": "^0.2.3",
    "es-toolkit": "^1.44.0",
    "kysely-codegen": "^0.20.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "pino-pretty": "^13.1.3",
    "type-fest": "^5.4.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.0.18"
  }
}
